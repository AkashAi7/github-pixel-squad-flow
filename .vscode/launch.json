{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Pixel Squad Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension/**/*.js"
      ],
      "preLaunchTask": "pixel-squad: build"
    }
  ]
}
